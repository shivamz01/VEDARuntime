# VEDA Runtime — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to Git.

# Required for production. Local demos may use demo-only fallback keys.
VEDA_HMAC_KEY=your-secret-hmac-key-here

# Local web app origin. Keep this concrete; do not use wildcard in production.
VEDA_API_CORS_ORIGIN=http://localhost:3101

# Optional provider routing threshold in milliseconds.
VEDA_PROVIDER_LATENCY_THRESHOLD_MS=5000

# Required for Pro Edition Supabase wiring.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Required only for issuing or verifying Pro license keys.
VEDA_LICENSE_SECRET=your-private-license-signing-secret
VEDA_LICENSE_KEY=your-issued-pro-license-key
