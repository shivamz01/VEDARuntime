# VEDA Runtime — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to Git.

# ─────────────────────────────────────────────
# REQUIRED (Free + Pro)
# ─────────────────────────────────────────────

# HMAC key for tamper-evident audit ledger entries.
# The runtime will FAIL TO START if this is missing in production.
# Use a long random string — minimum 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VEDA_HMAC_KEY=your-secret-hmac-key-here

# ─────────────────────────────────────────────
# OPTIONAL (Free Edition)
# ─────────────────────────────────────────────

# Allowed CORS origin for the API surface.
# Set this to your frontend URL in production.
# Default: * (wildcard — only safe for local development)
VEDA_API_CORS_ORIGIN=http://localhost:3000

# Provider latency threshold in milliseconds.
# If a provider's estimated latency exceeds this, the router skips it.
# Default: 5000
VEDA_PROVIDER_LATENCY_THRESHOLD_MS=5000

# ─────────────────────────────────────────────
# REQUIRED for Pro Edition (Supabase)
# ─────────────────────────────────────────────

# Your Supabase project URL.
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase service role key (not the anon key).
# Found in: Supabase Dashboard → Project Settings → API → service_role
# Keep this secret — it bypasses Row Level Security.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────
# OPTIONAL (Pro Edition)
# ─────────────────────────────────────────────

# License signing secret for issuing Pro license keys.
# Required only if you are running the license issuance workflow.
VEDA_LICENSE_SECRET=your-private-license-signing-secret

# Sovereign key for Pro license verification.
# Free Edition users do NOT set this — the runtime accepts "veda_local_free" automatically.
# Pro users receive their issued key after payment.
# VEDA_SOVEREIGN_KEY=your-issued-pro-key
